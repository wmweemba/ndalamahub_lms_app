# Required — server exits at boot if missing
MONGODB_URI=
JWT_SECRET=

# Optional
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
# set false to disable scheduled jobs, e.g. in one-off scripts
ENABLE_CRON=true
# Email (Resend). Unset RESEND_API_KEY = mail sending no-ops with a warn log (safe for dev/test)
RESEND_API_KEY=
FROM_EMAIL=support@mynexusgroup.com
FROM_NAME=NdalamaHub
APP_URL=http://localhost:5173
